<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
        xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
        xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
                            http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-4.23.xsd">

    <changeSet id="1-initial-schema" author="kara">
        <createTable tableName="package">
            <column name="package_id" type="varchar(50)">
                <constraints primaryKey="true" nullable="false"/>
            </column>
            <column name="order_id" type="varchar(50)">
                <constraints nullable="false"/>
            </column>
            <column name="sender" type="varchar(200)"/>
            <column name="recipient" type="varchar(200)"/>
            <column name="origin" type="varchar(50)"/>
            <column name="destination" type="varchar(50)"/>
            <column name="location" type="varchar(50)"/>
            <column name="weight_kg" type="numeric"/>
            <column name="priority" type="varchar(20)"/>
            <column name="courier_id" type="varchar(50)"/>
        </createTable>
    </changeSet>

</databaseChangeLog>